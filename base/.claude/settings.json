{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && exec bash \"$root/.claude/hooks/prompt-submit.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && exec bash \"$root/.claude/hooks/pre-tool.sh\"'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": []
  }
}
